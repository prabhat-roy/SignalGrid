# ============================================================
# SignalGrid — local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (subscriber, order, billing transactional) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=signalgrid
POSTGRES_PASSWORD=signalgrid
POSTGRES_DB=signalgrid

# ----- Lawful-Intercept PostgreSQL (siloed cluster) -----
LI_POSTGRES_HOST=localhost
LI_POSTGRES_PORT=5433
LI_POSTGRES_USER=li_app
LI_POSTGRES_PASSWORD=change-me
LI_POSTGRES_DB=lawful_intercept

# ----- Cassandra (CDR archive — billions of records) -----
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=cdr_archive

# ----- TimescaleDB (network performance metrics) -----
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5434
TIMESCALE_DB=network_metrics
TIMESCALE_USER=signalgrid
TIMESCALE_PASSWORD=signalgrid

# ----- ClickHouse (revenue/churn/network OLAP) -----
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=signalgrid_olap

# ----- MongoDB (catalogue, content) -----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=catalogue

# ----- Redis (real-time cache, sessions, prepaid balance) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Kafka (CDR mediation, domain events) -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- NATS JetStream -----
NATS_URL=nats://localhost:4222

# ----- SMPP (SMS gateway) -----
SMPP_HOST=localhost
SMPP_PORT=2775
SMPP_SYSTEM_ID=signalgrid
SMPP_PASSWORD=change-me

# ----- DIAMETER (LTE/5G AAA) -----
DIAMETER_REALM=signalgrid.local
DIAMETER_HOST=signalgrid-aaa.local

# ----- SIP signalling -----
SIP_HOST=localhost
SIP_PORT=5060

# ----- Object storage (MinIO — TAP files, invoice PDF) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=signalgrid

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/signalgrid
OIDC_CLIENT_ID=signalgrid
OIDC_CLIENT_SECRET=change-me

# ----- Vault (HSM-backed for keys) -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- TM Forum partner API -----
TMF_API_BASE_URL=https://api.signalgrid.local
TMF_PARTNER_CLIENT_ID=partner
TMF_PARTNER_CLIENT_SECRET=change-me
